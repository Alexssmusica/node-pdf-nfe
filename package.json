{
    "name": "@alexssmusica/node-pdf-nfe",
    "version": "1.0.61",
    "description": "Modulo que auxilia na geração de NFe e NFCe",
    "main": "lib/index.js",
    "types": "lib/index.d.ts",
    "license": "MIT",
    "author": {
        "name": "Alex Santos de Souza"
    },
    "files": [
        "/lib",
        "package.json",
        "README.md"
    ],
    "keywords": [
        "NFe",
        "NFCe"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/Alexssmusica/node-pdf-nfe.git"
    },
    "scripts": {
        "version": "npm run format && git add -A src",
        "postversion": "git push && git push --tags",
        "test": "jest --passWithNoTests --no-cache --runInBand",
        "cleanDist": "npx rimraf lib",
        "build": "npm run cleanDist && tsc -p tsconfig.json && npm run copyXSD&& npm run copyTTF",
        "prettier": "prettier src/**/*.{js,ts} --write",
        "type": "tsc --project tsconfig.json",
        "copyXSD": "copyfiles -u 1 src/**/*.xsd lib/",
        "copyTTF": "copyfiles -u 1 src/**/*.ttf lib/"
    },
    "dependencies": {
        "bwip-js": "^3.4.0",
        "date-fns": "^2.29.3",
        "dotenv": "^16.0.3",
        "pdfkit": "^0.13.0",
        "qrcode": "^1.5.3",
        "xml2js": "^0.4.23"
    },
    "devDependencies": {
        "@types/bwip-js": "^3.2.0",
        "@types/date-fns": "^2.6.0",
        "@types/jest": "^29.4.1",
        "@types/node": "^18.15.2",
        "@types/pdfkit": "^0.12.9",
        "@types/qrcode": "^1.5.0",
        "@types/xml2js": "^0.4.11",
        "@typescript-eslint/eslint-plugin": "4.22.0",
        "@typescript-eslint/parser": "4.22.0",
        "copyfiles": "^2.4.1",
        "eslint": "7.25.0",
        "eslint-config-prettier": "8.3.0",
        "eslint-plugin-prettier": "3.4.0",
        "prettier": "2.2.1",
        "rimraf": "^5.0.0",
        "ts-node": "^10.9.1",
        "typescript": "^4.9.5"
    }
}
